# Contributor: Łukasz Jendrysik <scadu@yandex.com>
maintainer="matik <wierzejskimateusz8@gmail.com>"
pmosbuild="${pmosbuild:-false}"
case "$pmosbuild" in
        true)
            pkgname="xlibre-xserver-pmos"
            ;;
        *)
            pkgname="xlibre-xserver"
            ;;
esac
pkgver="25.1.6"
pkgrel=0
case "$pmosbuild" in
        true)
            pkgdesc="XLibre X servers (postmarketOS variant)"
            ;;
        *)
            pkgdesc="XLibre X servers"
            ;;
esac
url="https://github.com/X11Libre/xserver"
arch="all"
license="MIT"
options="suid"
subpackages="
	$pkgname-dbg
	$pkgname-dev
	$pkgname-doc
	xvfb
	$pkgname-xephyr
	$pkgname-xnest
	$pkgname-common::noarch
	"
depends="
	font-cursor-misc
	font-misc-misc
	mesa-egl
	xkbcomp
	xkeyboard-config
	$pkgname-common
	"

# postmarketOS variant uses systemd-logind instead of seatd for rootless X server launches which requires udevd and dbus
case "$pmosbuild" in
	true)
	    depends="$depends systemd-udevd"
	    ;;
	*)
	    depends="$depends seatd"
	    ;;
esac

depends_dev="
	libepoxy-dev
	libpciaccess-dev
	libxfont2-dev
	mesa-dev
	"
makedepends="
	$depends_dev
	eudev-dev
	libdrm-dev
	libx11-dev
	libxau-dev
	libxcb-dev
	libxcvt-dev
	libxdmcp-dev
	libxext-dev
	libxkbfile-dev
	libxshmfence-dev
	meson
	nettle-dev
	pixman-dev
	xcb-util-dev
	xcb-util-image-dev
	xcb-util-keysyms-dev
	xcb-util-renderutil-dev
	xcb-util-wm-dev
	xkbcomp-dev
	xorgproto
	xtrans
	"
case "$pmosbuild" in
        true)
            makedepends="$makedepends dbus-dev systemd-dev"
            ;;
        *)
            makedepends="$makedepends libseat-dev"
            ;;
esac

checkdepends="
	xdpyinfo
	xrandr
	xvinfo
	"
source="
    https://github.com/X11Libre/xserver/archive/refs/tags/xlibre-xserver-$pkgver.tar.gz
	fix-errno.patch
"
builddir="$srcdir/xserver-xlibre-xserver-$pkgver"

# the modesetting driver is now shipped with xserver
case "$pmosbuild" in
        true)
            provides="xf86-video-modesetting=$pkgver-r$pkgrel xlibre-xserver=$pkgver xlibre-xserver-dbg=$pkgver xlibre-xserver-doc=$pkgver xlibre-xserver-dev=$pkgver"
            ;;
        *)
            provides="xf86-video-modesetting=$pkgver-r$pkgrel"
            ;;
esac
# postmarketOS variant conflicts with the non postmarketOS variant
case "$pmosbuild" in
        true)
            replaces="xorg-server xf86-video-modesetting xlibre-xserver"
            ;;
        *)
            replaces="xorg-server xf86-video-modesetting xlibre-xserver-pmos"
            ;;
esac

